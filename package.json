{
    "name": "node-server",
    "version": "1.0.0",
    "private": true,
    "description": "Minimal Node HTTP server with one endpoint",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "tsx server.ts",
        "start:ws": "node dist/ws-server.js",
        "dev:ws": "tsx ws-server.ts",
        "start:chat": "node dist/ws-server.js",
        "dev:chat": "tsx ws-server.ts"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.21.2",
        "multer": "^1.4.5-lts.2",
        "pocketbase": "^0.25.2",
        "ws": "^8.18.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.23",
        "@types/multer": "^1.4.12",
        "@types/node": "^24.6.0",
        "@types/ws": "^8.5.13",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
    }
}